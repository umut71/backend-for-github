# ============================================================
# LOCAL PC HOSTING CONFIGURATION
# Your PC is the server. Mobile app connects via LAN IP.
# ============================================================

# 1. Find your PC's LAN IP: Windows cmd -> ipconfig -> IPv4 Address
# 2. Use that IP here so mobile/web can connect
# Example: DATABASE_URL=postgresql://postgres:postgres@192.168.1.100:5432/buzz
# Docker default: postgres/postgres@localhost:5432/buzz
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/buzz

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS S3 Configuration (for video storage)
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_FOLDER_PREFIX=buzz/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Application Settings
APP_ORIGIN=http://localhost:3000
NODE_ENV=development
PORT=3000

# CORS Configuration - Add your frontend domains (comma-separated)
# Production example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://mobile.yourdomain.com
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
FRONTEND_URL=http://localhost:8081

# Required: Google AdMob (Revenue from ads)
# Get from admob.google.com → Apps → App settings
GOOGLE_ADMOB_APP_ID_ANDROID=ca-app-pub-4929253136106656~xxxxxxxxx
GOOGLE_ADMOB_APP_ID_IOS=ca-app-pub-4929253136106656~xxxxxxxxx

# Ad Unit IDs (create these in AdMob dashboard)
ADMOB_BANNER_UNIT_ID=ca-app-pub-4929253136106656/xxxxxxxxxx
ADMOB_REWARDED_UNIT_ID=ca-app-pub-4929253136106656/xxxxxxxxxx
ADMOB_INTERSTITIAL_UNIT_ID=ca-app-pub-4929253136106656/xxxxxxxxxx

# Optional: COPPA compliance - set to true for apps targeting children
# COPPA_RESTRICTED=false

# Optional: For payment processing (if using Stripe)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: For email notifications (if implementing)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Agora (Livestream)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# Jamendo (Music/Sounds API)
JAMENDO_CLIENT_ID=your-jamendo-client-id

# AbacusAI (AI Filters & Moderation)
ABACUSAI_API_KEY=your-abacusai-api-key

# Optional: For Redis (if implementing caching)
# REDIS_URL=redis://localhost:6379
# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/buzz

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS S3 Configuration (for video storage)
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_FOLDER_PREFIX=buzz/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Application Settings
APP_ORIGIN=http://localhost:3000
NODE_ENV=development
PORT=3000

# CORS Configuration - Add your frontend domains (comma-separated)
# Production example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://mobile.yourdomain.com
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
FRONTEND_URL=http://localhost:8081

# Optional: For Google AdMob (if implementing server-side ad management)
# GOOGLE_ADMOB_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx

# Optional: For payment processing (if using Stripe)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: For email notifications (if implementing)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: For Redis (if implementing caching)
# REDIS_URL=redis://localhost:6379